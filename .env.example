# ============================================================
# RAG TCE — Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ------------------------------------------------------------
# AZURE / DEEPSEEK — Inferência
# ------------------------------------------------------------
AZURE_ENDPOINT=https://gchec-mmmbyeag-eastus2.services.ai.azure.com/openai/v1/
AZURE_API_KEY=sua-chave-aqui
AZURE_MODEL_NAME=tce-DeepSeek-R1
AZURE_DEPLOYMENT_NAME=tce-DeepSeek-R1

# ------------------------------------------------------------
# EMBEDDING — Modelo e dimensões
# Opção A (Azure OpenAI): provider=azure_openai, dim=1536
# Opção B (Local HuggingFace): provider=huggingface, dim=768
# ------------------------------------------------------------
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMENSION=768
# Se usar Azure OpenAI para embedding:
# EMBEDDING_AZURE_ENDPOINT=https://seu-endpoint.openai.azure.com/
# EMBEDDING_AZURE_KEY=sua-chave-embedding
# EMBEDDING_AZURE_DEPLOYMENT=text-embedding-ada-002

# ------------------------------------------------------------
# POSTGRESQL / PGVECTOR
# ------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=rag_tce
PG_USER=postgres
PG_PASSWORD=sua-senha-aqui

# ------------------------------------------------------------
# PIPELINE RAG — Chunking e Retrieval
# ------------------------------------------------------------
# Diretório raiz para varredura de PDFs (suporta subdiretórios)
PDF_ROOT_DIR=/home/checon/documentos/pdfs

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CHUNK_SEPARATOR=\n\n

# Retrieval — quantos chunks retornar para montar o contexto
RETRIEVAL_TOP_K=5

# Similaridade mínima (cosine, 0.0 a 1.0) para incluir um chunk
RETRIEVAL_MIN_SCORE=0.30

# ------------------------------------------------------------
# FLASK
# ------------------------------------------------------------
FLASK_SECRET_KEY=troque-por-chave-aleatoria-segura
FLASK_PORT=5000
FLASK_DEBUG=True
